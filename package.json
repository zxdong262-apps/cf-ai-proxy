{
  "name": "cf-ai-proxy",
  "version": "1.0.0",
  "description": "Cloudflare Worker AI API Proxy with D1 database",
  "keywords": [
    "cloudflare",
    "ai",
    "proxy",
    "d1",
    "openai",
    "anthropic"
  ],
  "homepage": "https://github.com/zxdong262-apps/cf-ai-proxy#readme",
  "bugs": {
    "url": "https://github.com/zxdong262-apps/cf-ai-proxy/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zxdong262-apps/cf-ai-proxy.git"
  },
  "license": "MIT",
  "author": "ZHAO Xudong <zxdong@gmail.com>",
  "type": "module",
  "main": "src/worker.js",
  "scripts": {
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest",
    "db:init": "wrangler d1 execute ai-proxy-db --local --file=schema.sql",
    "db:init:remote": "wrangler d1 execute ai-proxy-db --remote --file=schema.sql",
    "db:reset": "wrangler d1 execute ai-proxy-db --local --command='DROP TABLE IF EXISTS routes; DROP TABLE IF EXISTS settings;' && npm run db:init"
  },
  "devDependencies": {
    "vitest": "^3.2.1",
    "wrangler": "^4.20.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
